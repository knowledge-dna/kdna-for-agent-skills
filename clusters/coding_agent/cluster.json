{
  "name": "coding_agent",
  "version": "0.2.0",
  "purpose": "Full-stack coding agent judgment: 7 KDNA domains + 7 detailed skills. Loads judgment for TDD, bug diagnosis, code review, architecture, requirements, shared language, and handoff.",
  "skills_dir": "../../skills",
  "packages": [
    {
      "id": "requirement_alignment",
      "role": "primary",
      "trigger_signals": ["feature", "implement", "build", "add", "create", "new", "开发", "实现", "新增"],
      "use_when": ["user request is vague", "task has hidden constraints", "agent is about to implement without enough context"]
    },
    {
      "id": "bug_diagnosis",
      "role": "secondary",
      "trigger_signals": ["bug", "fix", "debug", "broken", "crash", "error", "regression", "not working", "修复", "bug", "报错", "异常"],
      "use_when": ["bug report", "test failure", "performance regression", "runtime error"]
    },
    {
      "id": "test_driven_development",
      "role": "primary",
      "trigger_signals": ["test", "tdd", "red-green", "spec", "behavior", "测试", "TDD"],
      "use_when": ["new feature implementation", "bug fix with expected behavior", "regression prevention"]
    },
    {
      "id": "architecture_reasoning",
      "role": "secondary",
      "trigger_signals": ["architecture", "refactor", "design", "module", "boundary", "complexity", "zoom out", "large change", "架构", "重构", "设计"],
      "use_when": ["large change", "module boundary concern", "codebase complexity", "request to zoom out"]
    },
    {
      "id": "issue_decomposition",
      "role": "secondary",
      "trigger_signals": ["plan", "breakdown", "tasks", "issues", "triage", "estimate", "sprint", "计划", "分解", "任务"],
      "use_when": ["plan needs to become tasks", "PRD needs issue breakdown", "triage is requested"]
    },
    {
      "id": "shared_language",
      "role": "constraint",
      "trigger_signals": ["explain", "document", "write", "describe", "communicate", "说明", "解释", "文档", "描述"],
      "use_when": ["agent uses verbose descriptions", "agent communicates with user", "terminology precision matters"]
    },
    {
      "id": "handoff_context",
      "role": "secondary",
      "trigger_signals": ["done", "complete", "finish", "summary", "handoff", "next steps", "完成", "总结", "交接"],
      "use_when": ["task is complete", "context needs to be preserved for next session", "agent is about to end work"]
    }
  ],
  "composition": {
    "mode": "signal_driven",
    "primary_always_loaded": true,
    "conflict_reporting": true
  }
}
